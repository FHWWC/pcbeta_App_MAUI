<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PCBetaMAUI"
             xmlns:conv="clr-namespace:PCBetaMAUI.Converters"
             x:Class="PCBetaMAUI.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <conv:BoolInvertConverter x:Key="BoolInvertConverter"/>
            <conv:StringToBoolConverter x:Key="StringToBoolConverter"/>
            <conv:ListCountToBoolConverter x:Key="ListCountToBoolConverter"/>
            <conv:StringNotEqualZeroConverter x:Key="StringNotEqualZeroConverter"/>
            <conv:StringNotNullToBoolConverter x:Key="StringNotNullToBoolConverter"/>
            <conv:ExpandedToSymbolConverter x:Key="ExpandedToSymbolConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
